{
  "vim.handleKeys": {
    "<C-d>": true,
    "<C-p>": false,
    "<C-s>": false,
    "<C-z>": false
  },
  "vim.leader": "<space>",
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": ["<leader>", "c", "a"],
      "commands": ["editor.action.quickFix"]
    }
  ],
  "python.analysis.typeCheckingMode": "strict",
  "github.copilot.nextEditSuggestions.enabled": true,
}
